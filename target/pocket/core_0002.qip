set_instance_assignment -name PLL_COMPENSATION_MODE DIRECT -to "*core_0002*|altera_pll:altera_pll_i*|*"
set_instance_assignment -name PLL_CHANNEL_SPACING "0.0 KHz" -to "*core_0002*|altera_pll:altera_pll_i*|*"
set_instance_assignment -name PLL_AUTO_RESET OFF -to "*core_0002*|altera_pll:altera_pll_i*|*"
set_instance_assignment -name PLL_BANDWIDTH_PRESET AUTO -to "*core_0002*|altera_pll:altera_pll_i*|*"
set_global_assignment -name VERILOG_FILE [file join $::quartus(qip_path) "core_0002.v"]
