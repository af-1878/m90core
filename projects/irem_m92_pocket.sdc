# M90 V35 CPU multicycle paths (runs with clock enable, not every clk_sys cycle)
set_multicycle_path -from {core_top:ic|m90:m90_inst|V35:v35|*} -to {core_top:ic|m90:m90_inst|V35:v35|*} -setup 2
set_multicycle_path -from {core_top:ic|m90:m90_inst|V35:v35|*} -to {core_top:ic|m90:m90_inst|V35:v35|*} -hold 1

# Video PLL clock only drives the scaler DDR output - false path everything else
set_false_path -from [get_clocks {ic|video_pll_inst|video_pll_inst|altera_pll_i|general[0].gpll~PLL_OUTPUT_COUNTER|divclk}]
set_false_path -to   [get_clocks {ic|video_pll_inst|video_pll_inst|altera_pll_i|general[0].gpll~PLL_OUTPUT_COUNTER|divclk}]
