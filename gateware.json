{
    "name": "irem_m90",
    "version": "1.0.0",
    "description": "Irem M90 Arcade Hardware for Analogue Pocket",
    "repository": "https://github.com/flynny/irem_m90-pocket",
    "scripts": {
        "build:pocket": "quartus_sh --flow compile projects/irem_m92_pocket.qpf",
